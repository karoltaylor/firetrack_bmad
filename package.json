{
  "name": "fastapi-full-stack-template",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "scripts": {
    "dev": "bun run --filter frontend dev",
    "storybook": "bun run --filter frontend storybook",
    "build-storybook": "bun run --filter frontend build-storybook",
    "chromatic": "bun run --filter frontend chromatic",
    "lint": "bun run --filter frontend lint",
    "typecheck": "bun run --filter frontend typecheck",
    "check:icon-policy": "node ./scripts/check-icon-policy.mjs",
    "check:image-policy": "node ./scripts/check-image-policy.mjs",
    "check:contrast": "node ./scripts/check-contrast-pairs.mjs",
    "test": "bun run --filter frontend test",
    "test:axe": "bun run --filter frontend test:e2e:axe",
    "test:lighthouse": "bun run --filter frontend test:lighthouse",
    "test:ui": "bun run --filter frontend test:e2e:ui",
    "test:policy": "node --test ./scripts/tests/*.test.mjs"
  }
}
