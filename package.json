{
  "name": "fastapi-full-stack-template",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --filter frontend dev",
    "lint": "bun run --filter frontend lint",
    "check:icon-policy": "node ./scripts/check-icon-policy.mjs",
    "check:image-policy": "node ./scripts/check-image-policy.mjs",
    "test": "bun run --filter frontend test",
    "test:ui": "bun run --filter frontend test:e2e:ui",
    "test:policy": "node --test ./scripts/tests/*.test.mjs"
  }
}
