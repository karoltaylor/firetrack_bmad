# Domain / stack identity
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
PROJECT_NAME=firetrack
STACK_NAME=firetrack
ENVIRONMENT=local

# Backend auth
SECRET_KEY=changethis
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# Superuser (created on first startup)
FIRST_SUPERUSER=admin@firetrack.app
FIRST_SUPERUSER_PASSWORD=changethis

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Redis (Celery broker + reference data cache)
REDIS_URL=redis://redis:6379/0

# Email (optional in dev)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@firetrack.app
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Frontend API base (used by Vite dev server)
VITE_API_URL=http://localhost:8000

# Sentry (leave empty to disable)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Docker image names
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
